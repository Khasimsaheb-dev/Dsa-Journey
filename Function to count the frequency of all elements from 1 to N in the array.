class Solution {
  public:
    // Function to count the frequency of all elements from 1 to N in the array.
    vector<int> frequencyCount(vector<int>& arr) {
        // code here
        int n=arr.size();
        vector<int>hash(n+1,0);
        for(int i=0;i<n;i++){
            if(arr[i]>=1&&arr[i]<=n){
            hash[arr[i]]++;
        }
        }
        vector<int>ans;
        for(int i=1;i<=n;i++){
            ans.push_back(hash[i]);
        }
        
        
        return ans;
    }
};
