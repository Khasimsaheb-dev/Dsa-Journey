class Solution {
  public:
    int missingNum(vector<int>& arr) {
        // code here
        long long sum=0;
        for(int i=0;i<arr.size();i++){
            sum +=arr[i];
        }
        int n=arr.size();
       
        long long total = 1LL *((n+1) *(n+2))/2;
        
        return (int)  (total-sum) ;
        
        
    }
};
